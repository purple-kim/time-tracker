{
  "name": "time-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "A floating desktop pomodoro companion with an animated cat.",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "pack:mac": "electron-builder --mac dir"
  },
  "build": {
    "appId": "com.purplekim.timetracker",
    "productName": "Time Tracker",
    "asar": true,
    "files": [
      "index.html",
      "styles.css",
      "main.js",
      "calendar-data.js",
      "google-calendar-config.json",
      "google-calendar-config.example.json",
      "electron/**/*",
      "assets/**/*",
      "package.json",
      "!unused-assets-archive/**/*",
      "!node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "target": [
        "dir"
      ]
    }
  },
  "devDependencies": {
    "electron": "^32.3.3",
    "electron-builder": "^26.8.1"
  }
}
